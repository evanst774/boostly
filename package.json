{
  "name": "boostly-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:ignore-eslint": "next build --no-lint",
    "start": "next start -p 8080",
    "lint": "next lint",
    "db:push:dev": "dotenv -e .env.development -- drizzle-kit push",
    "db:push:prod": "dotenv -e .env.production -- drizzle-kit push",
    "db:generate": "dotenv -e .env.development -- drizzle-kit generate",
    "db:generate:prod": "dotenv -e .env.production -- drizzle-kit generate",
    "db:migrate:dev": "dotenv -e .env.development -- drizzle-kit migrate",
    "db:migrate:prod": "dotenv -e .env.production -- drizzle-kit migrate",
    "db:studio": "dotenv -e .env.development -- drizzle-kit studio",
    "db:studio:prod": "dotenv -e .env.production -- drizzle-kit studio",
    "db:drop": "dotenv -e .env.development -- drizzle-kit drop",
    "db:check": "dotenv -e .env.development -- drizzle-kit check",
    "db:drop:prod": "dotenv -e .env.production -- drizzle-kit drop",
    "db:reset:prod": "npm run db:drop:prod && npm run db:push:prod",
    "seed": "tsx src/lib/db/seeds/index.ts",
    "seed:dev": "dotenv -e .env.development -- tsx src/lib/db/seeds/index.ts",
    "seed:prod": "dotenv -e .env.production -- tsx src/lib/db/seeds/index.ts",
    "seed:rbac": "tsx src/lib/db/seeds/rbac-seed.ts",
    "seed:rbac:dev": "dotenv -e .env.development -- tsx src/lib/db/seeds/rbac-seed.ts",
    "seed:rbac:prod": "dotenv -e .env.production -- tsx src/lib/db/seeds/rbac-seed.ts",
    "seed:clear": "dotenv -e .env.development -- tsx src/lib/db/seeds/clear-seed.ts",
    "seed:reset": "npm run seed:clear && npm run seed:dev",
    "reset:dev": "npm run db:drop && npm run db:push:dev && npm run seed:dev",
    "reset:prod": "npm run db:drop && npm run db:push:prod && npm run seed:prod"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@headlessui/react": "^2.2.9",
    "@hello-pangea/dnd": "^18.0.1",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.17.3",
    "@otp-lib/authenticator": "^0.2.1",
    "@otp-lib/core": "^0.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-google-maps/api": "^2.20.8",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@vercel/functions": "^3.7.4",
    "antd": "^6.3.1",
    "apexcharts": "^5.15.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.35.1",
    "gsap": "^3.12.5",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "next-pwa": "^5.6.0",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.7",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "puppeteer-core": "^25.1.0",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-apexcharts": "^2.1.0",
    "react-chartjs-2": "^5.3.1",
    "react-day-picker": "^10.0.0",
